# ============================================================
#  Smart Kitchen Backend — Environment Variables
#  Kopjo si .env dhe plotëso vlerat
# ============================================================

PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── MySQL ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root

# Opsioni 1 — Password plaintext (development):
DB_PASSWORD=your_mysql_password_here

# Opsioni 2 — Password i enkriptuar AES-256 (production):
# 1. Vendos ENV_MASTER_KEY si variabël sistemi (JO në .env):
#    Windows:   set ENV_MASTER_KEY=your_32_char_secret_key_here
#    Linux/Mac: export ENV_MASTER_KEY=your_32_char_secret_key_here
# 2. Gjenero passwordin e enkriptuar:
#    node util/env-encrypt.js encrypt "fjalëkalimi_yt"
# 3. Vendos output-in këtu:
#    DB_PASSWORD=ENC:a1b2c3...:d4e5f6...

DB_NAME=smart_kitchen

# ── MongoDB ──────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/smart_kitchen_logs

# ── JWT — NDRYSHO me string random 32+ karaktere ─────────────
ACCESS_TOKEN_SECRET=change_this_to_a_long_random_secret_min_32_chars
REFRESH_TOKEN_SECRET=change_this_to_another_long_random_secret_min_32_chars
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# ── bcrypt ───────────────────────────────────────────────────
SALT_ROUNDS=12

# ── ML Service ───────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000
