# ============================================================
#  Smart Kitchen Backend — Environment Variables
#  Kopjo si .env dhe plotëso vlerat
# ============================================================

PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── MySQL ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root

# Rekomanduar për dorëzim: password i enkriptuar AES-256.
# 1. Gjenero sekretin:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 2. Vendose si DB_PASSWORD_SECRET.
# 3. Enkripto password-in:
#    node util/env-encrypt.util.js encrypt "fjalëkalimi_yt"
# 4. Vendos output-in te DB_PASSWORD_ENCRYPTED.
DB_PASSWORD_ENCRYPTED=ENC:a1b2c3...:d4e5f6...
DB_PASSWORD_SECRET=your_local_secret_key_here

# Fallback vetëm për development lokal nëse nuk përdoret DB_PASSWORD_ENCRYPTED:
# DB_PASSWORD=your_mysql_password_here

DB_NAME=smart_kitchen

# ── MongoDB ──────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/smart_kitchen_logs

# ── JWT — NDRYSHO me string random 32+ karaktere ─────────────
ACCESS_TOKEN_SECRET=change_this_to_a_long_random_secret_min_32_chars
REFRESH_TOKEN_SECRET=change_this_to_another_long_random_secret_min_32_chars
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# ── bcrypt ───────────────────────────────────────────────────
SALT_ROUNDS=12

# ── ML Service ───────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000
